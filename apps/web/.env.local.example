# Forge Terminal web — local dev environment template.
# Copy this file to .env.local and fill in real values before running `npm run dev`.
# .env.local is gitignored; .env.local.example is committed for reference.

# Base URL of the backend API. Used for both REST and (after http→ws swap) WebSocket.
# Local dev default:
#   NEXT_PUBLIC_API_URL=http://localhost:8000
# Production (Vercel): set in dashboard → Settings → Environment Variables.
#   NEXT_PUBLIC_API_URL=https://forge-terminal-production.up.railway.app
NEXT_PUBLIC_API_URL=http://localhost:8000
