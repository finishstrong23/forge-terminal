DATABASE_URL=postgresql://postgres:postgres@localhost:5432/forge_terminal
REDIS_URL=redis://localhost:6379/0
SECRET_KEY=change-me-in-production
# Set ENVIRONMENT=production in prod to enforce fail-closed hardening.
ENVIRONMENT=development
# Optional: seed the owner account on startup so a DB reset doesn't lock
# the owner out (owner emails can't self-register). Change after first login.
OWNER_INITIAL_PASSWORD=
HELIUS_API_KEY=your-helius-api-key
HELIUS_RPC_URL=https://mainnet.helius-rpc.com/?api-key=your-key
HELIUS_WEBHOOK_SECRET=
# Helius credit control. WEBHOOK_ENABLED=false deletes the program-wide
# webhook (the firehose, ~95% of credit spend) and runs poll-only — keeps
# free-tier usage sustainable pre-launch. Poll cadences in seconds.
WEBHOOK_ENABLED=true
DISCOVERY_POLL_SECONDS=300
ENRICH_POLL_SECONDS=300
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=
SENTRY_DSN=
STRIPE_PRICE_PRO_MONTHLY=
STRIPE_PRICE_PRO_YEARLY=
FRONTEND_URL=http://localhost:3000
# SMTP (alert emails)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
ALERT_FROM_EMAIL=alerts@forgeterminal.com
